{
  "expo": {
    "name": "Spackl",
    "slug": "spackl",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spackl",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "gbrousseau",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spackl.app"
    },
    "android": {
      "package": "com.spackl.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/b8838a7f-18f1-465c-a19b-e0ca63a2eafd"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b8838a7f-18f1-465c-a19b-e0ca63a2eafd"
      }
    }
  }
}