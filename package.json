{
  "name": "spackl",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "expo start -c",
    "prebuild": "expo prebuild --clean",
    "dev": "npx expo start --tunnel --clear",
    "build:web": "expo export --platform web",
    "build:android": "expo export --platform android",
    "build:ios": "expo export --platform ios",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "android": "npm run prebuild && expo run:android",
    "ios": "npm run prebuild && expo run:ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "start": "npm run prebuild && expo start --tunnel"
  },
